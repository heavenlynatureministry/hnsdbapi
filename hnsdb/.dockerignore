# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
eggs/
*.egg

# Virtual Environment
venv/
env/
.env
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
*.cover

# Documentation
docs/
README.md
LICENSE

# Logs
logs/
*.log

# Uploads (use volumes)
uploads/*
!uploads/.gitkeep

# Backups (use volumes)
backups/*
!backups/.gitkeep

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# OS
.DS_Store
Thumbs.db

# Environment files
.env
.env.*
!.env.example

# Node (if any)
node_modules/
package-lock.json

# Nginx
nginx/

# CI/CD
.github/
.gitlab-ci.yml